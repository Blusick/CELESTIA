# ─────────────────────────────────────────────────────────────
#  SKYLAND CONFIG
#  Copy this file to ".env" and adjust values as needed.
# ─────────────────────────────────────────────────────────────

# HTTP + WebSocket port
PORT=3000

# Public websocket URL the browser connects to.
# Leave blank to auto-derive from the page host (recommended for local dev).
PUBLIC_WS_URL=

# ── SOLANA / $SKY TOKEN ──────────────────────────────────────
# Solana cluster RPC endpoint.
#   mainnet:  https://api.mainnet-beta.solana.com
#   devnet:   https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta

# $SKY token mint (contract address)
SKY_TOKEN_MINT=8fa3FLWEk4Y7XLAGsQT8tpA8EcfsfQ9ZgEQVYcAvpump

# Decimals of the $SKY SPL token (pump.fun tokens are usually 6)
SKY_TOKEN_DECIMALS=6

# Treasury wallet that receives territory-purchase payments
TREASURY_WALLET=DwDoTqae91mTDMskLJgvjwiXz8rsTADdTAxH9YeA4Niq

# ── GAME ECONOMY ─────────────────────────────────────────────
# Cost (in whole $SKY) to buy one block of territory
TERRITORY_PRICE_SKY=10000

# Marketplace fee taken by the treasury, as a fraction (0.02 = 2%)
MARKETPLACE_FEE=0.02
